# ── AI ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=ArogyaMitra
OPENROUTER_TIMEOUT=60
OPENROUTER_MAX_RETRIES=3
OPENROUTER_MAX_TOKENS=4096

# ── YouTube (optional — falls back to search URLs if empty) ──────────────────
YOUTUBE_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local):
DATABASE_URL=sqlite:///./arogyamitra.db
# Supabase Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=5/minute
RATE_LIMIT_DEFAULT=60/minute

# ── Server / GCP ──────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
# Set ENVIRONMENT=production for Cloud Run

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG=true
